#!/usr/bin/env bash
# ============================================================================
# GENERATED FILE — DO NOT EDIT BY HAND.
# Produced by plugin/scripts/generate-plugin-hooks.ts from the generators in
# backend/src/mcp-server/utils/hookGenerators.ts (single source of truth).
# Regenerate with: cd backend && npx tsx ../plugin/scripts/generate-plugin-hooks.ts
# Project-ID-agnostic: generated with an empty projectId (safety floor is pure-local).
# ============================================================================
# .claude/hooks/pre-tool-use
# The Collective — Pre-tool-use safety hook (v2.1 — stdin JSON input)
# Validates Bash commands server-side before execution.
# Exit codes: 0 = allow, 2 = blocked (message shown to user)
# Fails open on network/parse errors (exit 0).
# Auto-generated by generate-claude-hooks.ts — do not edit manually
# HOOK_VERSION: 2026-06-15.1

set -euo pipefail

# ── Read Claude Code hook payload from stdin (JSON) ──
CLAUDE_TOOL_NAME=""
CLAUDE_TOOL_INPUT=""
CLAUDE_HOOK_EVENT=""
CLAUDE_SESSION_ID=""
if [ ! -t 0 ] && command -v jq &> /dev/null; then
  _HOOK_INPUT=$(cat 2>/dev/null || true)
  if [ -n "$_HOOK_INPUT" ]; then
    CLAUDE_TOOL_NAME=$(printf '%s' "$_HOOK_INPUT" | jq -r '.tool_name // empty' 2>/dev/null || true)
    CLAUDE_TOOL_INPUT=$(printf '%s' "$_HOOK_INPUT" | jq -c '.tool_input // {}' 2>/dev/null || echo '{}')
    CLAUDE_HOOK_EVENT=$(printf '%s' "$_HOOK_INPUT" | jq -r '.hook_event_name // empty' 2>/dev/null || true)
    CLAUDE_SESSION_ID=$(printf '%s' "$_HOOK_INPUT" | jq -r '.session_id // empty' 2>/dev/null || true)
  fi
  unset _HOOK_INPUT
fi
# ── End stdin reader ──

# Only intercept Bash tool calls
if [ "${CLAUDE_TOOL_NAME:-}" != "Bash" ]; then
  exit 0
fi

# Extract the command from tool input JSON
COMMAND=$(printf '%s' "$CLAUDE_TOOL_INPUT" | jq -r '.command // empty' 2>/dev/null)
if [ -z "$COMMAND" ]; then
  exit 0
fi

# Read API URL + auth from .mcp.json
MCP_CONFIG=""
for config_path in ".mcp.json" "$HOME/.mcp.json"; do
  if [ -f "$config_path" ]; then
    MCP_CONFIG="$config_path"
    break
  fi
done

if [ -z "$MCP_CONFIG" ]; then
  # No config found — fail open
  exit 0
fi

API_URL=""
AUTH_TOKEN=""

_MCP_URL=$(jq -r '.mcpServers["collective"].url // empty' "$MCP_CONFIG" 2>/dev/null)
_API_URL_EXPLICIT=$(jq -r '.mcpServers["collective"].apiUrl // empty' "$MCP_CONFIG" 2>/dev/null)
if [ -n "$_MCP_URL" ]; then
  AUTH_TOKEN=$(jq -r '.mcpServers["collective"].headers.Authorization // empty' "$MCP_CONFIG" 2>/dev/null)
fi

# Prefer explicit apiUrl (REST API on a separate host); fall back to stripping /mcp off the MCP url.
# The REST endpoints (e.g. /api/mcp/validate-bash) may live on api.X.dev while the MCP endpoint lives on mcp.X.dev —
# those are different hosts, not subpaths.
if [ -n "$_API_URL_EXPLICIT" ]; then
  API_URL="$_API_URL_EXPLICIT"
else
  API_URL="${_MCP_URL%/mcp}"
fi

# NOTE: the "no API_URL/AUTH_TOKEN → fail open (exit 0)" gate used to sit HERE.
# That meant a tokenless operator — the normal state under Clerk OAuth, which
# writes no Authorization header to .mcp.json — exited BEFORE the client-side
# catastrophic denylist below, so 'rm -rf /' etc. were silently ALLOWED. The gate
# now lives just before the validate-bash API call (after the denylist), so the
# pure-regex denylist + SQL guard (both local, token-free) always run. Everything
# between here and there self-guards on an empty AUTH_TOKEN (sql-guard returns 0;
# heartbeat/telemetry curls fire-and-forget with an empty header).
BASE_URL="$API_URL"

# ── SQL Schema Guard (ENGPLAN-006) ──
# Surfaces table schema + dual-semantic semantic when SQL queries filter
# on a confusable column against a registered dual-semantic table.
# Fails open on any internal error. Never breaks legitimate queries.

_sqlguard_run() {
  # All work inside a function so we can return early without affecting
  # the parent script's exit handling. The function returns 0 (allow) or
  # 2 (block); the caller propagates via 'exit' after the function returns.

  local cmd="$1"
  local mode="$2"

  # 1. Mode check
  if [ "$mode" = "OFF" ]; then
    return 0
  fi

  # 2. Detect SQL invocation patterns. Conservative — only matches the
  #    common shapes: direct psql, railway connect, node-with-pg.
  # NOTE: portable word boundaries via (^|[^[:alnum:]_])...($|[^[:alnum:]_])
  # instead of  — BSD grep on macOS (default /usr/bin/grep) does not
  # reliably support  (GNU regex extension). Without this, the entire
  # guard becomes a silent no-op for macOS operators.
  if ! echo "$cmd" | grep -qE '((^|[^[:alnum:]_])psql($|[^[:alnum:]_])|railway[[:space:]]+connect[[:space:]]+postgres|node[[:space:]]+-e[[:space:]]+.*pg)'; then
    return 0  # not a SQL invocation
  fi

  # 3. Acknowledgment marker short-circuit — operator (Claude) deliberately
  #    confirms the query is intentional by adding this comment to the SQL.
  if echo "$cmd" | grep -qF -- '-- @schema-acknowledged'; then
    return 0
  fi

  # 4. Extract SQL fragment. Handles -c 'SQL' and -c "SQL" forms; heredocs
  #    are best-effort (we extract everything after <<TAG until matching TAG).
  local sql=""
  sql=$(echo "$cmd" | grep -oE "(-c[[:space:]]+'[^']+'|-c[[:space:]]+\"[^\"]+\")" | head -1 | sed -E "s/^-c[[:space:]]+['\"]//" | sed -E "s/['\"]$//")
  if [ -z "$sql" ]; then
    sql=$(echo "$cmd" | sed -nE '/<<[[:space:]]*[A-Z_]+/,$p' | head -c 4096)
  fi
  if [ -z "$sql" ]; then
    sql="$cmd"
  fi

  # 5. Note whether a confusable column is referenced. This NO LONGER gates the
  #    guard — column surfacing now fires for ANY allowlisted table. The flag is
  #    used only to decide the stronger dual-semantic BLOCK case (step 12).
  #    Case-insensitive (defensive — a user may write ORGID uppercase).
  # Portable word boundaries via (^|[^[:alnum:]_]) instead of  — BSD grep on
  # macOS does not reliably support . Same rationale as step 2.
  local has_confusable=0
  if echo "$sql" | grep -qiE '(^|[^[:alnum:]_])(orgId|projectId|userId|clientId|apiKeyId|operatorOrgId)($|[^[:alnum:]_])'; then
    has_confusable=1
  fi

  # 6. Target table — first FROM/INTO/UPDATE in the SQL. Handles optional
  #    schema-qualified names like 'public.command_audit_logs' by stripping
  #    the schema prefix and keeping the table name. Otherwise the regex
  #    would capture 'public' and miss the dual-semantic registry check.
  local target_table=""
  target_table=$(echo "$sql" | grep -oiE '(FROM|INTO|UPDATE)[[:space:]]+([a-zA-Z_][a-zA-Z0-9_]*\.)?[a-zA-Z_][a-zA-Z0-9_]*' | head -1 | awk '{print $2}' | sed 's/.*\.//')
  if [ -z "$target_table" ]; then
    return 0  # couldn't identify a table; bail out (fail-open)
  fi

  # 7. Is the target table a registered dual-semantic table? This NO LONGER
  #    gates the guard — non-dual allowlisted tables still get their columns
  #    surfaced. It only decides the stronger BLOCK path (step 12) and whether
  #    to bypass the session cache.
  local is_dual=0
  if echo "$target_table" | grep -qiE '^(command_audit_logs)$'; then
    is_dual=1
  fi

  # 8. Session cache check. Anchored to $HOME/.claude so the cache survives
  #    CWD changes within the same session. CLAUDE_SESSION_ID is populated
  #    from the stdin payload; falls back to a per-hook-invocation marker
  #    when missing (slightly over-noisy but never wrong).
  local sid="${CLAUDE_SESSION_ID:-}"
  if [ -z "$sid" ]; then
    sid="nopid-$$"
  fi
  local cache_dir="$HOME/.claude"
  mkdir -p "$cache_dir" 2>/dev/null || true
  local cache_file="$cache_dir/.sql-schema-seen.${sid}"
  # Only the dual-semantic BLOCK case bypasses the cache — it must re-evaluate
  # every time so a prior column-surface can't silence a real block (the ack
  # marker at step 3 is its intentional bypass, not the cache). Every other path
  # surfaces a table's columns at most once per session.
  local bypass_cache=0
  if [ "$mode" = "BLOCK" ] && [ "$has_confusable" = "1" ] && [ "$is_dual" = "1" ]; then
    bypass_cache=1
  fi
  if [ "$bypass_cache" = "0" ] && [ -f "$cache_file" ] && grep -qxF "$target_table" "$cache_file" 2>/dev/null; then
    return 0  # already surfaced this table this session — pass silently
  fi

  # 9. Fetch schema. Fail-open if API unreachable or returns non-2xx.
  if [ -z "$BASE_URL" ] || [ -z "$AUTH_TOKEN" ]; then
    echo "[sql-schema-guard] AUTH_TOKEN or BASE_URL empty — failing open." >&2
    return 0
  fi

  # mktemp for tmpfile — $$ alone races under concurrent hook invocations.
  local tmpfile
  tmpfile=$(mktemp -t sqlguard.XXXXXXXX 2>/dev/null || echo "/tmp/sqlguard-$$-$RANDOM.json")

  # 2s connect, 5s total. Single attempt — never retry.
  local http_status
  http_status=$(curl -s -o "$tmpfile" -w "%{http_code}" \
    --connect-timeout 2 --max-time 5 \
    -H "Authorization: $AUTH_TOKEN" \
    "$BASE_URL/api/admin/schema/$target_table" 2>/dev/null || echo "000")

  if [ "$http_status" != "200" ]; then
    echo "[sql-schema-guard] Schema lookup returned HTTP $http_status — failing open. (Hook reachable: yes; schema endpoint: no.)" >&2
    rm -f "$tmpfile" 2>/dev/null || true
    return 0
  fi

  local schema_json
  schema_json=$(cat "$tmpfile" 2>/dev/null)
  rm -f "$tmpfile" 2>/dev/null || true

  if [ -z "$schema_json" ]; then
    echo "[sql-schema-guard] Schema response empty — failing open." >&2
    return 0
  fi

  # 10. Fire-and-forget telemetry POST so rollout success / false-positive
  #     rate can be measured server-side. Backgrounded — never blocks even
  #     if the endpoint is down.
  curl -s --connect-timeout 1 --max-time 2 \
    -X POST "$BASE_URL/api/admin/schema-guard-event" \
    -H "Content-Type: application/json" \
    -H "Authorization: $AUTH_TOKEN" \
    -d "{\"table\":\"$target_table\",\"mode\":\"$mode\",\"action\":\"fire\",\"sessionId\":\"$sid\"}" \
    >/dev/null 2>&1 &

  # 11. Build the block message once. It is delivered on TWO channels:
  #     - stderr: the human transcript (every fire, both modes)
  #     - stdout as PreToolUse JSON additionalContext: the MODEL's context
  #       (surface/WARN path only — issue #344: stderr on exit 0 NEVER
  #       reaches the model. The 2026-06-05 #337 session proved it: the
  #       guard fired on organizations + projects, the schema went to
  #       stderr, and the agent still guessed wrong column names.)
  local dual_note
  dual_note=$(echo "$schema_json" | jq -r '.dualSemanticNote // empty' 2>/dev/null)
  local example_op
  example_op=$(echo "$schema_json" | jq -r '.exampleQueries.operatorScoped // empty' 2>/dev/null)
  local example_cl
  example_cl=$(echo "$schema_json" | jq -r '.exampleQueries.clientScoped // empty' 2>/dev/null)
  local columns_render
  columns_render=$(echo "$schema_json" | jq -r '.columns[] | "  - " + .name + " : " + .type + (if .nullable then " (nullable)" else " (NOT NULL)" end) + (if .semantic then "  ← " + .semantic else "" end)' 2>/dev/null)

  local render
  render=$(
    echo "=== SQL SCHEMA GUARD (ENGPLAN-006) ==="
    echo ""
    echo "Live schema for \"$target_table\" — these are the REAL column names from"
    echo "information_schema (prod truth). Use them; do not guess from Prisma models."
    echo ""
    if [ -n "$dual_note" ]; then
      echo "⚠ $dual_note"
      echo ""
    fi
    echo "Schema for $target_table:"
    echo "$columns_render"
    if [ -n "$example_op" ] || [ -n "$example_cl" ]; then
      echo ""
      echo "Example correct queries:"
      [ -n "$example_op" ] && echo "  operator-scoped: $example_op"
      [ -n "$example_cl" ] && echo "  client-scoped:   $example_cl"
    fi
    echo ""
    echo "If your query is intentional, add this comment to the SQL and re-run:"
    echo "    -- @schema-acknowledged"
  )

  # 12. Mode-dependent exit + cache semantics.
  #     WARN: cache the table (we've shown the schema; future queries pass).
  #     BLOCK: do NOT cache — every flagged query is blocked until
  #     -- @schema-acknowledged is added. The ack marker short-circuit at
  #     step 3 handles the acknowledged case.
  if [ "$mode" = "BLOCK" ] && [ "$is_dual" = "1" ] && [ "$has_confusable" = "1" ]; then
    {
      echo ""
      printf '%s\n' "$render"
      echo ""
      echo "Mode: BLOCK — query blocked (dual-semantic table + confusable column)."
      echo "This block persists until the SQL includes the marker comment above."
      echo "(Fires on every such query without acknowledgment.)"
      echo ""
    } >&2
    return 2
  fi

  # Surface path: columns shown, query allowed. Cache the table so it's surfaced
  # at most once per session. Reached for any allowlisted table — and for the
  # dual-semantic table in WARN mode or without a confusable column.
  {
    echo ""
    printf '%s\n' "$render"
    echo ""
  } >&2
  # Model-visible channel: a single PreToolUse JSON object on stdout, exit 0.
  # Claude Code injects additionalContext next to the tool result. We
  # deliberately do NOT emit any permission decision field — pre-approving
  # the command would bypass the user's permission prompt; omitting it
  # leaves the normal permission flow untouched. The allow paths of the
  # surrounding pre-tool-use hook write nothing else to stdout, so this is
  # the whole stdout contract (one valid JSON object).
  printf '%s' "$render" | jq -Rs '{hookSpecificOutput:{hookEventName:"PreToolUse",additionalContext:.}}' 2>/dev/null || true
  echo "$target_table" >> "$cache_file" 2>/dev/null || true
  return 0
}

# Read guard mode from .mcp.json. Resolution order:
#   .mcp.json present + sqlGuardMode key set     → that value
#   .mcp.json present + sqlGuardMode key absent  → WARN (default)
#   .mcp.json missing OR jq unavailable          → OFF (fail-safe — no
#     AUTH_TOKEN available anyway, guard would fail-open immediately).
_sqlguard_mode="OFF"
if [ -n "${MCP_CONFIG:-}" ] && command -v jq &>/dev/null; then
  _sqlguard_mode=$(jq -r '.mcpServers.collective.sqlGuardMode // "WARN"' "$MCP_CONFIG" 2>/dev/null || echo "OFF")
fi

# Run the guard. Returning 2 here propagates as 'exit 2' to Claude Code.
set +e
_sqlguard_run "$COMMAND" "$_sqlguard_mode"
_sqlguard_rc=$?
set -e
if [ $_sqlguard_rc -eq 2 ]; then
  exit 2
fi
# ── End SQL Schema Guard ──

# ── Periodic heartbeat (fire-and-forget, re-sends every 12h) ──
HEARTBEAT_MARKER="$HOME/.collective-hook-heartbeat"
SEND_HEARTBEAT=false
if [ ! -f "$HEARTBEAT_MARKER" ]; then
  SEND_HEARTBEAT=true
else
  # Re-send if marker is older than 12 hours (43200 seconds)
  if [ "$(uname)" = "Darwin" ]; then
    MARKER_MTIME=$(stat -f %m "$HEARTBEAT_MARKER" 2>/dev/null || echo 0)
  else
    MARKER_MTIME=$(stat -c %Y "$HEARTBEAT_MARKER" 2>/dev/null || echo 0)
  fi
  NOW=$(date +%s)
  MARKER_AGE=$(( NOW - MARKER_MTIME ))
  if [ $MARKER_AGE -gt 43200 ]; then
    SEND_HEARTBEAT=true
  fi
fi
if [ "$SEND_HEARTBEAT" = "true" ]; then
  curl -s --connect-timeout 2 --max-time 3 \
    -X POST "$BASE_URL/api/mcp/hook-heartbeat" \
    -H "Content-Type: application/json" \
    -H "Authorization: $AUTH_TOKEN" \
    -d '{"hookType":"pre-tool-use","hookVersion":"2026-06-15.1"}' \
    >/dev/null 2>&1 &
  touch "$HEARTBEAT_MARKER" 2>/dev/null || true
fi

# ── Known-safe command cache (no API call, ~0ms) ──
KNOWN_SAFE_EXACT="ls|pwd|cat|head|tail|wc|echo|find|grep|which|whoami|date|env|printenv|tree|file|du|df"

CMD_FIRST=$(echo "$COMMAND" | awk '{print $1}')
IS_KNOWN_SAFE=false

# Check exact single-word matches
if echo "$CMD_FIRST" | grep -qwE "^($KNOWN_SAFE_EXACT)$"; then
  IS_KNOWN_SAFE=true
fi

# Check prefix matches (read-only, standard dev commands)
if [ "$IS_KNOWN_SAFE" = "false" ]; then
  for PREFIX in "git status" "git log" "git diff" "git branch" "git show" "git remote" "git stash list" "npm test" "npm run test" "npm run lint" "npx tsc" "npx jest" "npx vitest" "node -e" "node -p" "python -c"; do
    case "$COMMAND" in
      "$PREFIX"*) IS_KNOWN_SAFE=true; break ;;
    esac
  done
fi

# ── Compliance counting ──
# Prefer Claude Code's session_id (stable across every hook invocation in one
# session) so the per-session TOTAL counter accumulates properly. Falling back
# to $$ — the bash PID — resets the counter on every invocation because Claude
# Code spawns a new bash subshell per hook call, and TOTAL % 10 never hits 0,
# so report_checkpoint never fires, so compliance_checkpoints stays empty.
# That was the silent failure discovered 2026-04-23: 87 source='hook' rows
# shipped fine post-Phase-8-P0 fix but zero checkpoint rows across the fleet.
SESSION_MARKER="${CLAUDE_SESSION_ID:-${COLLECTIVE_SESSION:-$$}}"
COUNT_DIR="/tmp/.collective-counts"
mkdir -p "$COUNT_DIR" 2>/dev/null

TOTAL_FILE="${COUNT_DIR}/total-${SESSION_MARKER}"
SAFE_FILE="${COUNT_DIR}/safe-${SESSION_MARKER}"
API_FILE="${COUNT_DIR}/api-${SESSION_MARKER}"
BLOCKED_FILE="${COUNT_DIR}/blocked-${SESSION_MARKER}"

# Always increment total
TOTAL=$(cat "$TOTAL_FILE" 2>/dev/null || echo "0")
TOTAL=$((TOTAL + 1))
echo "$TOTAL" > "$TOTAL_FILE"

report_checkpoint() {
  local SAFE_CT=$(cat "$SAFE_FILE" 2>/dev/null || echo "0")
  local API_CT=$(cat "$API_FILE" 2>/dev/null || echo "0")
  local BLKD_CT=$(cat "$BLOCKED_FILE" 2>/dev/null || echo "0")
  (
    curl -s --connect-timeout 2 --max-time 2 \
      -X POST "$BASE_URL/api/mcp/compliance-checkpoint" \
      -H "Content-Type: application/json" \
      -H "Authorization: $AUTH_TOKEN" \
      -d "{\"sessionMarker\":\"${SESSION_MARKER}\",\"clientBashCount\":${TOTAL},\"knownSafeCount\":${SAFE_CT},\"apiValidatedCount\":${API_CT},\"apiBlockedCount\":${BLKD_CT}}" \
      > /dev/null 2>&1
  ) &
}

if [ "$IS_KNOWN_SAFE" = "true" ]; then
  # Known-safe: count locally, skip API call entirely
  SAFE=$(cat "$SAFE_FILE" 2>/dev/null || echo "0")
  SAFE=$((SAFE + 1))
  echo "$SAFE" > "$SAFE_FILE"

  # Checkpoint on first command of session, then every 10. Short sessions
  # (<10 cmds) previously never checked in — 0–1.2% of expected rate fleet-wide.
  [ "$TOTAL" -eq 1 ] || [ $((TOTAL % 10)) -eq 0 ] && report_checkpoint
  exit 0
fi

# ── HA-T1-21: Client-side catastrophic-pattern denylist ──
# This runs BEFORE the API call so it BLOCKS even when validate-bash is
# unreachable. Closes the silent fail-open gap exposed by the 2026-05-04
# outage: when api.thecollectiveai.dev was down for 30 min, every operator's
# safety hook silently disabled (curl failed → exit 0 → command allowed).
#
# Patterns here are deliberately conservative — only commands that are
# unambiguously catastrophic and have essentially no legitimate use case.
# False-block on these is recoverable (operator sees BLOCKED message, can
# investigate / contact support); false-allow is data-loss-class.
#
# DO NOT add patterns that have legitimate uses (e.g. `rm -rf node_modules`,
# `DROP TABLE temp_foo`). Those go on the server-side rules engine where
# context-aware logic decides; the client denylist is the floor, not the
# whole rule set.
#
# Implementation note: previously a bash `case` with glob patterns. That
# version (2026-05-04.1) had unescaped spaces in patterns that bash's case
# parser rejected, breaking every non-known-safe Bash call. Replaced with
# grep -qE which is portable, testable in isolation, and fork cost (~5ms
# total across all rules) is negligible vs the existing curl roundtrip.
DENY_REASON=""

if echo "$COMMAND" | grep -qE 'rm[[:space:]]+(-[a-zA-Z]*[rR][a-zA-Z]*[fF][a-zA-Z]*|-[a-zA-Z]*[fF][a-zA-Z]*[rR][a-zA-Z]*|--recursive[[:space:]]+--force|--force[[:space:]]+--recursive)[[:space:]]+/([[:space:]]|$|[^a-zA-Z0-9_-])'; then
  DENY_REASON="Recursive deletion of root filesystem"
elif echo "$COMMAND" | grep -qE '[$]HOME/[.][.]'; then
  DENY_REASON="Recursive deletion of home parent"
elif echo "$COMMAND" | grep -qE ':[(][)][[:space:]]*[{][[:space:]]*:[|]:[[:space:]]*&[[:space:]]*[}][[:space:]]*;[[:space:]]*:'; then
  DENY_REASON="Fork bomb"
elif echo "$COMMAND" | grep -qE '(^|[^a-zA-Z0-9_-])dd[[:space:]]+.*of=/dev/(sd|disk|nvme|hd)'; then
  DENY_REASON="dd to raw disk device — irreversible data loss"
elif echo "$COMMAND" | grep -qE 'mkfs[.][a-zA-Z0-9]+[[:space:]]+([^[:space:]]+[[:space:]]+)*(/dev/(sd|disk|nvme|hd)|/([[:space:]]|$))'; then
  DENY_REASON="Filesystem reformat on a real disk device"
elif echo "$COMMAND" | grep -qE 'chmod[[:space:]]+-R[[:space:]]+[0-9]+[[:space:]]+/([[:space:]]|$)'; then
  DENY_REASON="Recursive chmod on root filesystem"
elif echo "$COMMAND" | grep -qE 'chown[[:space:]]+-R[[:space:]]+[^[:space:]]+[[:space:]]+/([[:space:]]|$)'; then
  DENY_REASON="Recursive chown on root filesystem"
elif echo "$COMMAND" | grep -qE 'git[[:space:]]+push[[:space:]]+(-f|--force(-with-lease(=[^[:space:]]+)?)?)([[:space:]]+[^[:space:]]+)*[[:space:]]+(main|master|prod|production)([[:space:]]|$)'; then
  DENY_REASON="Force-push to a protected branch (main/master/prod)"
elif echo "$COMMAND" | grep -iqE 'drop[[:space:]]+database'; then
  DENY_REASON="DROP DATABASE — entire database deletion"
elif echo "$COMMAND" | grep -iqE '(delete[[:space:]]+from|truncate|drop[[:space:]]+table)[[:space:]]+_prisma_migrations'; then
  DENY_REASON="Tampering with _prisma_migrations table — schema state corruption"
fi

if [ -n "$DENY_REASON" ]; then
  BLKD=$(cat "$BLOCKED_FILE" 2>/dev/null || echo "0")
  BLKD=$((BLKD + 1))
  echo "$BLKD" > "$BLOCKED_FILE"
  # Best-effort tell the server (fire-and-forget; server may be down)
  (
    curl -s --connect-timeout 2 --max-time 2 \
      -X POST "$BASE_URL/api/mcp/hook-failure" \
      -H "Content-Type: application/json" \
      -H "Authorization: $AUTH_TOKEN" \
      -d "{\"reason\":\"client_denylist\",\"hookVersion\":\"2026-06-15.1\",\"rule\":$(echo "$DENY_REASON" | jq -Rs .),\"command\":$(echo "$COMMAND" | head -c 80 | jq -Rs .)}" \
      > /dev/null 2>&1
  ) &
  echo "BLOCKED by The Collective client-side safety floor" >&2
  echo "Rule: $DENY_REASON" >&2
  echo "Severity: critical" >&2
  echo "" >&2
  echo "This is a catastrophic-pattern block enforced by the hook itself," >&2
  echo "not the server. It runs even when api.thecollectiveai.dev is down." >&2
  echo "If you genuinely need this command, contact the platform owner." >&2
  exit 2
fi

# ── Not known-safe and not client-denied: call API for real validation ──
# Auth gate (relocated from above the denylist): with no API_URL/AUTH_TOKEN — the
# normal state for an OAuth operator — the local safety floor (denylist + SQL guard,
# both already ran above) is all we can enforce, so fail open on the SERVER call.
if [ -z "$API_URL" ] || [ -z "$AUTH_TOKEN" ]; then
  exit 0
fi

API_CT=$(cat "$API_FILE" 2>/dev/null || echo "0")
API_CT=$((API_CT + 1))
echo "$API_CT" > "$API_FILE"

# Capture current git branch for branch-context-aware safety rules (e.g. BLOCK
# force-push only when on main/master). Falls back to empty string if not in
# a git repo — server-side rules with requiresBranch will skip themselves.
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")

RESPONSE_RAW=$(curl -s -w "\n%{http_code}" --connect-timeout 2 --max-time 3 \
  -X POST "$BASE_URL/api/mcp/validate-bash" \
  -H "Content-Type: application/json" \
  -H "Authorization: $AUTH_TOKEN" \
  -d "{\"command\": $(echo "$COMMAND" | jq -Rs .), \"currentBranch\": $(echo "$CURRENT_BRANCH" | jq -Rs .)}" \
  2>/dev/null) || {
  # Validation API unreachable — report failure (fire-and-forget), then fail open
  (
    curl -s --connect-timeout 2 --max-time 2 \
      -X POST "$BASE_URL/api/mcp/hook-failure" \
      -H "Content-Type: application/json" \
      -H "Authorization: $AUTH_TOKEN" \
      -d "{\"reason\":\"curl_failed\",\"hookVersion\":\"2026-06-15.1\",\"command\":$(echo "$COMMAND" | head -c 80 | jq -Rs .)}" \
      > /dev/null 2>&1
  ) &
  [ "$TOTAL" -eq 1 ] || [ $((TOTAL % 10)) -eq 0 ] && report_checkpoint
  exit 0
}

# Split the captured body from the trailing HTTP status (-w appended the code on its own line).
VALIDATE_HTTP=$(printf '%s' "$RESPONSE_RAW" | tail -n1)
RESPONSE=$(printf '%s' "$RESPONSE_RAW" | sed '$d')

# Expired/revoked token: the call authenticated but got 401/403. An expired
# token is NOT a dangerous command — FAIL OPEN (exit 0); blocking every Bash
# call over an auth problem would be far worse. But warn the operator once per
# session, since the next collective_* call otherwise just hangs in mcp-remote.
if [ "$VALIDATE_HTTP" = "401" ] || [ "$VALIDATE_HTTP" = "403" ]; then
  TOKEN_EXPIRED_MARKER="${COUNT_DIR}/token-expired-${SESSION_MARKER}"
  if [ ! -f "$TOKEN_EXPIRED_MARKER" ]; then
    touch "$TOKEN_EXPIRED_MARKER" 2>/dev/null || true
    echo "" >&2
    echo "════════════════════════════════════════════════════════" >&2
echo "[The Collective] YOUR PROJECT TOKEN (col_) HAS EXPIRED OR BEEN REVOKED (HTTP 401)." >&2
echo "MCP tools (collective_*) will hang or fail until the token is replaced --" >&2
echo "mcp-remote retries the dead token internally, which is why calls appear to freeze." >&2
echo "To fix:" >&2
echo "  1. Open the Admin Hub (app.thecollectiveai.dev), open your project, then" >&2
echo "     the Collaborators tab, and Rotate your key (or use Create API Key)." >&2
echo "  2. Replace the col_ value in this project .mcp.json in BOTH places:" >&2
echo "       - the mcp-remote --header Authorization: Bearer col_... argument" >&2
echo "       - the headers.Authorization field" >&2
echo "  3. Run /exit, then reopen so the MCP connection re-establishes." >&2
    echo "════════════════════════════════════════════════════════" >&2
    echo "" >&2
  fi
  exit 0
fi

# Parse response
BLOCKED=$(echo "$RESPONSE" | jq -r '.blocked // false' 2>/dev/null)

if [ "$BLOCKED" = "true" ]; then
  BLKD=$(cat "$BLOCKED_FILE" 2>/dev/null || echo "0")
  BLKD=$((BLKD + 1))
  echo "$BLKD" > "$BLOCKED_FILE"
  report_checkpoint  # Always checkpoint on blocks

  RULE=$(echo "$RESPONSE" | jq -r '.violation.rule // "Unknown rule"' 2>/dev/null)
  SEVERITY=$(echo "$RESPONSE" | jq -r '.violation.severity // "critical"' 2>/dev/null)
  echo "BLOCKED by The Collective safety rules" >&2
  echo "Rule: $RULE" >&2
  echo "Severity: $SEVERITY" >&2
  exit 2
fi

# Checkpoint on first command of session, then every 10. See known-safe branch for rationale.
[ "$TOTAL" -eq 1 ] || [ $((TOTAL % 10)) -eq 0 ] && report_checkpoint

exit 0