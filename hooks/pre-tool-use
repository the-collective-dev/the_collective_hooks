#!/usr/bin/env bash
# ============================================================================
# GENERATED FILE — DO NOT EDIT BY HAND.
# Produced by plugin/scripts/generate-plugin-hooks.ts from the generators in
# backend/src/mcp-server/utils/hookGenerators.ts (single source of truth).
# Regenerate with: cd backend && npx tsx ../plugin/scripts/generate-plugin-hooks.ts
# Project-ID-agnostic: generated with an empty projectId (safety floor is pure-local).
# ============================================================================
# The Collective — local catastrophic-command safety floor (plugin).
# LOCAL ONLY: no network, no .mcp.json, no credentials, zero egress. Blocks the
# unambiguously-catastrophic commands offline. The LIVE server-side rules engine runs
# separately via the mcp_tool PreToolUse hook (collective_validate_command).
#
# REQUIRES jq to parse the hook stdin. If jq is missing the command can't be read and the
# floor cannot evaluate it — it warns on stderr and exits 0 (fail-open) rather than
# blocking every command. Claude Code environments ship jq; a host without it has no LOCAL
# floor (the server-side mcp_tool validation still applies when connected).
set -uo pipefail

if ! command -v jq >/dev/null 2>&1; then
  echo "[collective] WARNING: jq not found — local catastrophic-command floor is INACTIVE." >&2
  exit 0
fi

input=$(cat 2>/dev/null || true)
COMMAND=$(printf '%s' "$input" | jq -r '.tool_input.command // empty' 2>/dev/null || true)
if [ -z "$COMMAND" ]; then exit 0; fi

DENY_REASON=""

if echo "$COMMAND" | grep -qE 'rm[[:space:]]+(-[a-zA-Z]*[rR][a-zA-Z]*[fF][a-zA-Z]*|-[a-zA-Z]*[fF][a-zA-Z]*[rR][a-zA-Z]*|--recursive[[:space:]]+--force|--force[[:space:]]+--recursive)[[:space:]]+/([[:space:]]|$|[^a-zA-Z0-9_-])'; then
  DENY_REASON="Recursive deletion of root filesystem"
elif echo "$COMMAND" | grep -qE '[$]HOME/[.][.]'; then
  DENY_REASON="Recursive deletion of home parent"
elif echo "$COMMAND" | grep -qE ':[(][)][[:space:]]*[{][[:space:]]*:[|]:[[:space:]]*&[[:space:]]*[}][[:space:]]*;[[:space:]]*:'; then
  DENY_REASON="Fork bomb"
elif echo "$COMMAND" | grep -qE '(^|[^a-zA-Z0-9_-])dd[[:space:]]+.*of=/dev/(sd|disk|nvme|hd)'; then
  DENY_REASON="dd to raw disk device — irreversible data loss"
elif echo "$COMMAND" | grep -qE 'mkfs[.][a-zA-Z0-9]+[[:space:]]+([^[:space:]]+[[:space:]]+)*(/dev/(sd|disk|nvme|hd)|/([[:space:]]|$))'; then
  DENY_REASON="Filesystem reformat on a real disk device"
elif echo "$COMMAND" | grep -qE 'chmod[[:space:]]+-R[[:space:]]+[0-9]+[[:space:]]+/([[:space:]]|$)'; then
  DENY_REASON="Recursive chmod on root filesystem"
elif echo "$COMMAND" | grep -qE 'chown[[:space:]]+-R[[:space:]]+[^[:space:]]+[[:space:]]+/([[:space:]]|$)'; then
  DENY_REASON="Recursive chown on root filesystem"
elif echo "$COMMAND" | grep -qE 'git[[:space:]]+push[[:space:]]+(-f|--force(-with-lease(=[^[:space:]]+)?)?)([[:space:]]+[^[:space:]]+)*[[:space:]]+(main|master|prod|production)([[:space:]]|$)'; then
  DENY_REASON="Force-push to a protected branch (main/master/prod)"
elif echo "$COMMAND" | grep -iqE 'drop[[:space:]]+database'; then
  DENY_REASON="DROP DATABASE — entire database deletion"
elif echo "$COMMAND" | grep -iqE '(delete[[:space:]]+from|truncate|drop[[:space:]]+table)[[:space:]]+_prisma_migrations'; then
  DENY_REASON="Tampering with _prisma_migrations table — schema state corruption"
fi

if [ -n "$DENY_REASON" ]; then
  echo "BLOCKED by The Collective local safety floor" >&2
  echo "Rule: $DENY_REASON" >&2
  echo "This catastrophic-pattern block runs locally in the plugin hook — offline, no network, no credentials." >&2
  echo "If you genuinely need this command, contact the platform owner." >&2
  exit 2
fi

exit 0
