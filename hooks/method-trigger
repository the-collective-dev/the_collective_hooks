#!/usr/bin/env bash
# .claude/hooks/method-trigger (plugin — LOCAL-ONLY methodology trigger)
# ============================================================================
# WHY A HOOK AND NOT ONLY A SKILL:
#   Skills are PULLED (the model decides to load one). Hooks are PUSHED (they
#   fire deterministically). A methodology skill the session never chooses to
#   load is a suggestion that did not arrive. This hook detects the moment and
#   tells the session which skill to load — hook fires -> skill loads -> the
#   session drafts on-methodology.
#
# CHANNEL CHOICE (deliberate, verified):
#   UserPromptSubmit + PLAIN STDOUT is the proven injection path in this plugin
#   (the Claim Gate uses exactly this and reaches the model every turn).
#   PostToolUse plain stdout does NOT reach the model — it requires
#   hookSpecificOutput.additionalContext (see hooks/post-tool-use). Building
#   here avoids that silent-no-op class entirely.
#
# Pure-local: ZERO network egress, no token, no credentials read. Reads the
# prompt text only, matches literal keywords, prints a short nudge, exits 0.
# Low-noise by design: a signal nobody acts on is not governance, it is
# decoration. Strong signals only.
# ============================================================================
set -uo pipefail
payload="$(cat 2>/dev/null || true)"

# Extract the prompt field without requiring jq (portable, best-effort).
prompt="$(printf '%s' "$payload" | tr '\n' ' ' | sed -n 's/.*"prompt"[[:space:]]*:[[:space:]]*"\(.*\)/\1/p' | cut -c1-4000)"
[ -z "$prompt" ] && exit 0
lower="$(printf '%s' "$prompt" | tr '[:upper:]' '[:lower:]')"

hit_scope=0
for p in "can we also" "can you also" "could we also" "could you also" "also add" \
         "one more thing" "new scope" "out of scope" "change order" "change note" \
         "additional feature" "add a feature" "also want" "also need" "add support for" \
         "would it be possible" "quick addition" "small addition" "extra feature" \
         "on top of that" "while we are in there" "while you are in there"; do
  case "$lower" in *"$p"*) hit_scope=1; break;; esac
done

hit_comms=0
for p in "draft an email" "draft the email" "reply to the client" "send to the client" \
         "status report" "status update to" "client update" "send thomas" "send the client" \
         "write to the client" "proposal to" "before i send" "delivery note"; do
  case "$lower" in *"$p"*) hit_comms=1; break;; esac
done

[ "$hit_scope" -eq 0 ] && [ "$hit_comms" -eq 0 ] && exit 0

echo ""
echo "[Method Trigger] A methodology-governed moment was detected in this request."
[ "$hit_scope" -eq 1 ] && cat <<'__SCOPE__'
- Possible NEW SCOPE on a live engagement. Load the `c-change-note` skill before writing any
  code for it. Non-negotiable: no build starts on a verbal yes; the operator prices it; the
  client's written go must be on record. If the free-vs-new classification is ambiguous, say so
  in the draft and let the operator rule — do not silently classify it as free.
__SCOPE__
[ "$hit_comms" -eq 1 ] && cat <<'__COMMS__'
- Possible CLIENT-FACING COMMUNICATION. Load the `c-client-comms` skill and grade the draft
  before the operator sends. Watch the truth-tier ladder (built / live / delivered / paid —
  claim down when in doubt), never assert a billing fact, and sweep the artifact AND its
  attachments for internal notes. Never send it yourself.
__COMMS__
echo ""
exit 0
