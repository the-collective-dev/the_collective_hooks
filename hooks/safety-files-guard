#!/usr/bin/env bash
# ============================================================================
# GENERATED FILE — DO NOT EDIT BY HAND.
# Produced by plugin/scripts/generate-plugin-hooks.ts from the generators in
# backend/src/mcp-server/utils/hookGenerators.ts (single source of truth).
# Regenerate with: cd backend && npx tsx ../plugin/scripts/generate-plugin-hooks.ts
# Project-ID-agnostic: generated with an empty projectId (safety floor is pure-local).
# ============================================================================
# .claude/hooks/safety-files-guard
# The Collective — Pre-tool-use guard for Edit/Write/MultiEdit on safety files.
# Auto-generated by hookGenerators.ts — do not edit manually.
# HOOK_VERSION: 2026-06-15.1
#
# Reads Claude Code stdin JSON, blocks Edit/Write/MultiEdit operations
# whose file_path matches platform-safety paths. Other tools and other
# paths pass through (exit 0). Failure modes (no jq, no stdin) fail
# OPEN — never block legitimate edits because of hook misconfiguration.

set -euo pipefail

# stdin presence + jq required to evaluate. If either missing, fail open.
if [ -t 0 ] || ! command -v jq &> /dev/null; then
  exit 0
fi

_INPUT=$(cat 2>/dev/null || true)
if [ -z "$_INPUT" ]; then
  exit 0
fi

CLAUDE_TOOL_NAME=$(printf '%s' "$_INPUT" | jq -r '.tool_name // empty' 2>/dev/null || true)

# Only intercept Edit / Write / MultiEdit. Other tools pass through.
case "${CLAUDE_TOOL_NAME:-}" in
  Edit|Write|MultiEdit) ;;
  *) exit 0 ;;
esac

# Extract file_path from tool_input. If missing or empty, nothing to guard.
FILE_PATH=$(printf '%s' "$_INPUT" | jq -r '.tool_input.file_path // empty' 2>/dev/null)
if [ -z "$FILE_PATH" ]; then
  exit 0
fi

# Denylist regex. Matches:
#   - any file directly under .claude/hooks/  (the hook scripts themselves)
#   - .mcp.json at the end of any path        (MCP config + auth tokens)
#   - .claude/settings.local.json             (hook routing config)
if echo "$FILE_PATH" | grep -qE '/\.claude/hooks/[^/]+$|/\.mcp\.json$|/\.claude/settings\.local\.json$'; then
  echo "BLOCKED by The Collective safety-files-guard" >&2
  echo "" >&2
  echo "Path: $FILE_PATH" >&2
  echo "" >&2
  echo "Direct edits to platform-safety files are not permitted:" >&2
  echo "  .claude/hooks/*               — the safety hooks themselves" >&2
  echo "  .mcp.json                     — auth tokens + MCP config" >&2
  echo "  .claude/settings.local.json   — hook routing config" >&2
  echo "" >&2
  echo "These files are the platform safety floor. Local edits break the" >&2
  echo "integrity of the safety system that's supposed to govern this" >&2
  echo "session. Today's HA-T1-22 incident showed why this matters: when" >&2
  echo "the hook errored, edits-in-place produced a Frankenstein file" >&2
  echo "instead of pulling the platform's verified replacement." >&2
  echo "" >&2
  echo "To update hooks: run 'collective_setup_hooks' instead." >&2
  echo "  - Pulls the latest content from the platform server" >&2
  echo "  - Verified against server-side intent + audit-logged" >&2
  echo "  - Replaces ALL hook files in one transaction" >&2
  exit 2
fi

exit 0
